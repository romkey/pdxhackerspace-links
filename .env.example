# Copy to .env and adjust for local development.

# Database (docker-compose.dev defaults)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=links_development

# Redis (docker-compose.dev defaults)
REDIS_URL=redis://redis:6379/0

# App
APP_HOST=http://localhost:3000
# APP_VERSION is set automatically in Docker builds from git tags.

# CUPS print server (hostname:port). Docker dev defaults to host.docker.internal:631.
CUPS_SERVER=host.docker.internal:631
# Optional extra lp options for label queues, e.g. Cut=EveryPage for Brother QL cutters.
# CUPS_LABEL_OPTIONS=Cut=EveryPage

# Local sign-in (optional — one account from environment)
LOCAL_AUTH_EMAIL=admin@example.com
LOCAL_AUTH_PASSWORD=change-me
LOCAL_AUTH_NAME=Local Admin

# OpenID Connect (optional — omit to use local sign-in only)
# OIDC_ISSUER=https://auth.example.com/application/o/links/
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3000/auth/openid_connect/callback

# Production
# DATABASE_URL=postgres://user:pass@host:5432/links_production
# RAILS_MASTER_KEY=

# Error monitoring (optional — production/staging only)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
