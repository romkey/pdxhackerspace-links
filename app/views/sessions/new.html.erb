<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <h1 class="h-page-title mb-1">Sign in</h1>
      <p class="text-secondary text-13 mb-4">Access Links with your account.</p>

      <% if oidc_login_available? %>
        <div class="d-grid mb-3">
          <%= button_to "Sign in with OpenID Connect",
                        "/auth/openid_connect",
                        method: :post,
                        class: "btn btn-primary",
                        data: { turbo: false } %>
        </div>
      <% end %>

      <% if local_login_available? %>
        <% if oidc_login_available? %>
          <details>
            <summary class="text-13 text-secondary">Sign in locally</summary>
            <div class="mt-3">
              <%= render "sessions/local_login_form" %>
            </div>
          </details>
        <% else %>
          <%= render "sessions/local_login_form" %>
        <% end %>
      <% end %>

      <% unless oidc_login_available? || local_login_available? %>
        <div class="alert alert-warning text-13 mb-0">
          No sign-in method is configured. Set OIDC or LOCAL_AUTH environment variables.
        </div>
      <% end %>
    </div>
  </div>
</div>
