<% content_for :title, @thing.name %>

<div class="container-fluid py-4">
  <div class="d-flex align-items-end justify-content-between mb-3">
    <div>
      <div class="text-12 text-secondary mb-1">
        <%= link_to "Things", things_path, class: "text-secondary text-decoration-none" %>
        <span class="mx-1">/</span>
        <span class="text-body"><%= @thing.name %></span>
      </div>
      <h1 class="h-page-title mb-0"><%= @thing.name %></h1>
      <% if @thing.owner.present? || @thing.ip_address.present? %>
        <div class="text-13 text-secondary mt-1">
          <% if @thing.owner.present? %>
            <span><%= @thing.owner %></span>
          <% end %>
          <% if @thing.owner.present? && @thing.ip_address.present? %>
            <span class="mx-1">·</span>
          <% end %>
          <% if @thing.ip_address.present? %>
            <code class="text-12"><%= @thing.ip_address %></code>
          <% end %>
        </div>
      <% end %>
      <% if @thing.description.present? %>
        <div class="text-13 text-secondary mt-2"><%= simple_format(@thing.description) %></div>
      <% end %>
      <% if @thing.notes.present? %>
        <div class="mt-2">
          <div class="text-12 text-secondary mb-1">Notes</div>
          <div class="text-13 text-secondary"><%= simple_format(@thing.notes) %></div>
        </div>
      <% end %>
    </div>
    <% if can_manage_things? %>
      <div class="d-flex flex-wrap gap-2 justify-content-end">
        <%= render "print_controls", thing: @thing, printers: @printers, align_end: true %>
        <%= render "nfc_write", thing: @thing %>
        <%= button_to "Duplicate",
                      duplicate_thing_path(@thing),
                      method: :post,
                      class: "btn btn-outline-secondary btn-sm",
                      form: { class: "d-inline" } %>
        <%= link_to "Edit", edit_thing_path(@thing), class: "btn btn-primary btn-sm" %>
      </div>
    <% end %>
  </div>

  <% if @tracked_redirect %>
    <div class="status-panel status-attention mb-3 text-13"
         data-controller="redirect-countdown"
         data-redirect-countdown-url-value="<%= @tracked_redirect[:url] %>"
         data-redirect-countdown-seconds-value="<%= @tracked_redirect[:seconds] %>">
      Redirecting to <%= link_to @tracked_redirect[:title], @tracked_redirect[:url], class: "fw-medium" %>
      in <span data-redirect-countdown-target="countdown"><%= @tracked_redirect[:seconds] %></span> seconds…
    </div>
  <% end %>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="h-section-label mb-2">Links</div>
      <% if @thing.links_for_display.any? %>
        <div class="list-group list-compact">
          <% @thing.links_for_display.each do |link| %>
            <% href = link.safe_href %>

            <% if href %>
              <%= link_to href, target: "_blank", rel: "noopener", class: "list-group-item list-group-item-action py-2" do %>
                <div class="d-flex justify-content-between align-items-start gap-2">
                  <div>
                    <span><%= link.display_title %></span>
                    <% if link.note.present? %>
                      <div class="text-12 text-secondary mt-1"><%= link.note %></div>
                    <% end %>
                  </div>
                  <i class="bi bi-box-arrow-up-right text-secondary flex-shrink-0"></i>
                </div>
              <% end %>
            <% else %>
              <div class="list-group-item py-2">
                <div class="fw-medium text-13"><%= link.display_title %></div>
                <% if link.note.present? %>
                  <div class="text-12 text-secondary mt-1"><%= link.note %></div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-secondary text-13 mb-0">No links added yet.</p>
      <% end %>

      <div class="mt-4">
        <div class="h-section-label mb-2">Scan visits</div>
        <div class="text-13">
          <span class="<%= @thing.qr_scan_count.zero? ? 'text-secondary' : 'text-body' %>"><%= @thing.qr_scan_count %></span>
          <span class="text-secondary"> QR · </span>
          <span class="<%= @thing.nfc_scan_count.zero? ? 'text-secondary' : 'text-body' %>"><%= @thing.nfc_scan_count %></span>
          <span class="text-secondary"> NFC · </span>
          <span class="<%= @thing.visit_count.zero? ? 'text-secondary' : 'text-body' %>"><%= @thing.visit_count %></span>
          <span class="text-secondary"> visits</span>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <% if @thing.ar_anchor.attached? %>
        <div class="h-section-label mb-2">AR Anchor</div>
        <div class="mb-4">
          <%= image_tag @thing.ar_anchor, class: "img-fluid rounded border border-secondary-subtle w-100" %>
          <% if @thing.ar_anchor_note.present? %>
            <div class="text-12 text-secondary mt-2"><%= @thing.ar_anchor_note %></div>
          <% end %>
        </div>
      <% end %>
      <div class="h-section-label mb-2">Photos</div>
      <% if @thing.photos.any? %>
        <div class="row g-2">
          <% @thing.photos.each do |photo| %>
            <div class="col-6">
              <%= image_tag photo, class: "img-fluid rounded border border-secondary-subtle w-100" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-secondary text-13 mb-0">No photos yet.</p>
      <% end %>
    </div>
  </div>
</div>
