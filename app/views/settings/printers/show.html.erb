<% content_for :title, @printer.name %>

<%= settings_frame do %>
  <div class="mb-3">
    <div class="text-12 text-secondary mb-1">
      <%= link_to "Printers", settings_printers_path, class: "text-secondary text-decoration-none" %>
      <span class="mx-1">/</span>
      <span class="text-body"><%= @printer.name %></span>
    </div>
    <div class="d-flex align-items-end justify-content-between">
      <div>
        <h1 class="h-page-title mb-0"><%= @printer.name %></h1>
        <div class="text-13 text-secondary mt-1">
          <%= @printer.printer_type_label %>
          <% if @printer.cups? %>
            · <%= @printer.page_size_group_label %> · <%= @printer.cups_name %> @ <%= @printer.cups_server %>
          <% else %>
            · <%= @printer.label_height_mm %> mm strip
          <% end %>
        </div>
      </div>
      <div class="d-flex gap-2">
        <% if @printer.cups? %>
          <%= button_to "Test connection", test_connection_settings_printer_path(@printer),
                        class: "btn btn-outline-secondary btn-sm" %>
        <% end %>
        <%= button_to "Test print", test_print_settings_printer_path(@printer),
                      class: "btn btn-outline-secondary btn-sm" %>
        <%= link_to "Edit", edit_settings_printer_path(@printer), class: "btn btn-primary btn-sm" %>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-6">
      <% if @printer.cups? %>
        <div class="h-section-label mb-2">Connection</div>
        <dl class="row text-13 mb-0">
          <dt class="col-sm-4 text-secondary">CUPS server</dt>
          <dd class="col-sm-8"><code class="text-12"><%= @printer.cups_server %></code></dd>
          <dt class="col-sm-4 text-secondary">CUPS queue</dt>
          <dd class="col-sm-8"><%= @printer.cups_name %></dd>
          <dt class="col-sm-4 text-secondary">Page size</dt>
          <dd class="col-sm-8"><%= @printer.page_size_label %></dd>
          <dt class="col-sm-4 text-secondary">Type</dt>
          <dd class="col-sm-8"><%= @printer.page_size_group_label %></dd>
          <dt class="col-sm-4 text-secondary">CUPS media</dt>
          <dd class="col-sm-8"><code class="text-12"><%= @printer.cups_media %></code></dd>
          <% if @printer.avery_template.present? %>
            <dt class="col-sm-4 text-secondary">Avery template</dt>
            <dd class="col-sm-8"><%= @printer.avery_template_label %></dd>
          <% end %>
        </dl>
      <% else %>
        <div class="h-section-label mb-2">Command</div>
        <dl class="row text-13 mb-0">
          <dt class="col-sm-4 text-secondary">Label height</dt>
          <dd class="col-sm-8"><%= @printer.label_height_mm %> mm</dd>
          <dt class="col-sm-4 text-secondary">Print command</dt>
          <dd class="col-sm-8"><code class="text-12"><%= @printer.print_command %></code></dd>
        </dl>
      <% end %>
      <dl class="row text-13 mb-0 mt-3">
        <dt class="col-sm-4 text-secondary">Status</dt>
        <dd class="col-sm-8"><%= @printer.enabled? ? "Enabled" : "Disabled" %></dd>
      </dl>
    </div>
    <% if @printer.description.present? %>
      <div class="col-md-6">
        <div class="h-section-label mb-2">Notes</div>
        <p class="text-13 text-secondary mb-0"><%= simple_format(@printer.description) %></p>
      </div>
    <% end %>
  </div>
<% end %>
