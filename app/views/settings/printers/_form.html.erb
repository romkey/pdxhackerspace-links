<% content_for :title, title %>

<%= settings_frame do %>
  <div class="mb-3">
    <div class="text-12 text-secondary mb-1">
      <%= link_to "Printers", settings_printers_path, class: "text-secondary text-decoration-none" %>
      <span class="mx-1">/</span>
      <span class="text-body"><%= title %></span>
    </div>
    <h1 class="h-page-title mb-0"><%= title %></h1>
  </div>

  <%= form_with model: printer, url: printer.persisted? ? settings_printer_path(printer) : settings_printers_path,
                class: "vstack gap-4",
                data: {
                  controller: "printer-form cups-queues",
                  cups_queues_url_value: cups_queues_settings_printers_path,
                  action: "change->printer-form#sync"
                } do |form| %>
    <% if printer.errors.any? %>
      <div class="alert alert-danger text-13">
        <%= printer.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <div class="h-section-label mb-2">Printer type</div>
      <div class="row g-2">
        <div class="col-md-6">
          <div class="form-check border border-secondary-subtle rounded p-2 h-100">
            <%= form.radio_button :printer_type, "cups", class: "form-check-input", id: "printer_type_cups" %>
            <%= form.label :printer_type, for: "printer_type_cups", class: "form-check-label w-100" do %>
              <span class="fw-medium text-13">CUPS</span>
              <span class="d-block text-secondary text-12 mt-1">Send PDF labels to a remote CUPS queue (Brother, DYMO, laser, etc.)</span>
            <% end %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="form-check border border-secondary-subtle rounded p-2 h-100">
            <%= form.radio_button :printer_type, "command", class: "form-check-input", id: "printer_type_command" %>
            <%= form.label :printer_type, for: "printer_type_command", class: "form-check-label w-100" do %>
              <span class="fw-medium text-13">Command</span>
              <span class="d-block text-secondary text-12 mt-1">Generate a PNG and run a shell command with <%= Printer::PRINT_COMMAND_FILENAME %> set to the file path</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-md-6">
        <%= form.label :name, "Display name", class: "form-label" %>
        <%= form.text_field :name, class: "form-control", required: true %>
      </div>
      <div class="col-12">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, class: "form-control", rows: 2,
                           placeholder: "Front desk Brother QL-820NWB, workshop label script, etc." %>
      </div>
    </div>

    <div data-printer-form-target="cupsSection">
      <div class="h-section-label mb-2">Remote server</div>
      <p class="text-secondary text-13 mb-3">
        Each CUPS printer can use its own server on the network. Brother label printers, office lasers, and other queues do not need to share a host.
      </p>
      <div class="row g-3">
        <div class="col-md-6">
          <%= form.label :cups_server, "CUPS server", class: "form-label" %>
          <div class="input-group input-group-sm">
            <%= form.text_field :cups_server, class: "form-control",
                                placeholder: "192.168.1.20:631",
                                data: {
                                  printer_form_target: "cupsServer",
                                  cups_queues_target: "server",
                                  action: "change->cups-queues#refreshQueues blur->cups-queues#refreshQueues"
                                } %>
            <button type="button" class="btn btn-outline-secondary"
                    data-cups-queues-target="refreshButton"
                    data-action="click->cups-queues#refreshQueues">
              <i class="bi bi-arrow-clockwise"></i>
              Refresh queues
            </button>
          </div>
          <div class="form-text text-12">Hostname or IP with port. Default from <%= link_to "General settings", settings_site_path %> is <%= Printer.default_cups_server %>.</div>
        </div>
        <div class="col-md-6">
          <%= form.label :cups_name, "CUPS queue name", class: "form-label" %>
          <%= form.text_field :cups_name, class: "form-control",
                              list: "printer-cups-queues",
                              placeholder: "Brother_QL_820NWB",
                              data: { printer_form_target: "cupsName", cups_queues_target: "queue" } %>
          <datalist id="printer-cups-queues" data-cups-queues-target="list">
            <% cups_queues.each do |queue| %>
              <option value="<%= queue %>"></option>
            <% end %>
          </datalist>
          <div class="text-12 text-secondary mt-1" data-cups-queues-target="status"></div>
        </div>
      </div>
    </div>

    <div data-printer-form-target="commandSection" hidden>
      <div class="h-section-label mb-2">Command</div>
      <p class="text-secondary text-13 mb-3">
        Labels are rendered as PNG files and passed to your command. Use <%= Printer::PRINT_COMMAND_FILENAME %> as a placeholder for the saved file path.
      </p>
      <div class="row g-3">
        <div class="col-md-4">
          <%= form.label :label_height_mm, "Label height (mm)", class: "form-label" %>
          <%= form.number_field :label_height_mm, class: "form-control", min: 1, max: 200, step: 1,
                                placeholder: "24",
                                data: { printer_form_target: "labelHeight" } %>
          <div class="form-text text-12">Strip width for landscape labels (QR code on the left, text on the right).</div>
        </div>
        <div class="col-12">
          <%= form.label :print_command, "Print command", class: "form-label" %>
          <%= form.text_field :print_command, class: "form-control font-monospace text-12",
                              placeholder: "/usr/local/bin/print-label FILENAME",
                              data: { printer_form_target: "printCommand" } %>
          <div class="form-text text-12">Runs under bash. <%= Printer::PRINT_COMMAND_FILENAME %> is replaced with the escaped PNG path.</div>
        </div>
      </div>
    </div>

    <div data-printer-form-target="cupsSection">
      <div class="h-section-label mb-2">Page size</div>
      <p class="text-secondary text-13 mb-3">Choose the media size sent to CUPS for this printer.</p>
      <% Printer::PAGE_SIZE_GROUPS.each do |group_key, group_label| %>
        <% sizes = Printer::PAGE_SIZES.select { |_key, config| config[:group] == group_key } %>
        <% next if sizes.empty? %>

        <div class="mb-3">
          <div class="text-12 text-secondary mb-2"><%= group_label %></div>
          <div class="row g-2">
            <% sizes.each do |key, config| %>
              <div class="col-md-6">
                <div class="form-check border border-secondary-subtle rounded p-2 h-100">
                  <%= form.radio_button :page_size, key, class: "form-check-input", id: "printer_page_size_#{key}",
                                        data: { printer_form_target: "pageSize" } %>
                  <%= form.label :page_size, for: "printer_page_size_#{key}", class: "form-check-label w-100" do %>
                    <span class="fw-medium text-13"><%= config[:label] %></span>
                    <span class="d-block text-secondary text-12 mt-1"><%= config[:description] %></span>
                    <span class="d-block text-secondary text-11 mt-1">CUPS media: <%= config[:media] %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div data-printer-form-target="averySection">
      <div class="h-section-label mb-2">Avery template</div>
      <p class="text-secondary text-13 mb-3">Optional sheet layout for letter-size laser or inkjet printers using Avery stock.</p>
      <div class="col-md-6">
        <%= form.label :avery_template, "Template", class: "form-label" %>
        <%= form.select :avery_template,
                        options_for_select(
                          [["None (plain letter)", ""]] + Printer::AVERY_TEMPLATES.map { |key, config| [config[:label], key] },
                          printer.avery_template
                        ),
                        {},
                        class: "form-select" %>
      </div>
    </div>

    <div>
      <div class="h-section-label mb-2">Status</div>
      <div class="form-check">
        <%= form.check_box :enabled, class: "form-check-input" %>
        <%= form.label :enabled, "Enabled", class: "form-check-label" %>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= form.submit class: "btn btn-primary btn-sm" %>
      <%= link_to "Cancel", printer.persisted? ? settings_printer_path(printer) : settings_printers_path,
                  class: "btn btn-outline-secondary btn-sm" %>
      <% if printer.persisted? %>
        <%= button_to "Delete", settings_printer_path(printer), method: :delete,
                      class: "btn btn-outline-danger btn-sm",
                      form: { data: { turbo_confirm: "Delete #{printer.name}?" } } %>
      <% end %>
    </div>
  <% end %>
<% end %>
