#!/bin/bash -e

ensure_development_dependencies() {
  if [ "${RAILS_ENV}" != "development" ]; then
    return
  fi

  if ! bundle check >/dev/null 2>&1; then
    echo "Installing Ruby gems..."
    bundle install
  fi
}

ensure_development_dependencies

# bin/dev prepares the database; other dev commands (e.g. sidekiq) need it here.
if [ "${RAILS_ENV}" = "development" ] && [ "${@: -1:1}" != "./bin/dev" ]; then
  ./bin/rails db:prepare db:seed
elif [ "${@: -2:1}" = "./bin/rails" ] && [ "${@: -1:1}" = "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
